# Uygulama
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Veritabanı
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whatsapp_platform

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change_this_to_a_random_256_bit_secret
JWT_REFRESH_SECRET=change_this_to_another_random_256_bit_secret

# Şifreleme (WhatsApp session_data için AES-256-GCM)
SESSION_ENCRYPTION_KEY=608971e108dfafd750a55b083f6c8c7e09d6c71bdd2079a6257c19211d315421

# Superadmin Seed
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin123!

# 5SIM (Sanal numara servisi)
FIVESIM_API_KEY=
FIVESIM_COUNTRY=any
FIVESIM_OPERATOR=any
